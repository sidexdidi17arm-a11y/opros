# Скопируй этот файл в .env и заполни значения.
# .env в репозиторий не коммитится (см. .gitignore).

# Connection string из Neon (https://console.neon.tech → Dashboard → Connection Details).
# Используй pooled URL (hostname содержит "-pooler").
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Пароль для пишущих эндпоинтов API (POST/DELETE /api/data, POST /api/data/restore).
# Должен совпадать с паролем, который вводит админ во фронтенд-логине.
ADMIN_PASSWORD=replace-me

# Порт (опционально). По умолчанию 3000.
# PORT=3000
